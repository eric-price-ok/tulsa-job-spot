# =============================================================================
# TulsaJobSpot — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# Docker Compose file selection
# Tells `docker compose` to always layer the production overrides on top of
# the base file. Required on the production server — do not remove.
# ---------------------------------------------------------------------------
COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml

# ---------------------------------------------------------------------------
# Core (required)
# ---------------------------------------------------------------------------
DOMAIN=localhost
SECRET_KEY=change-me-to-a-random-64-character-string-use-openssl-rand-hex-32

# PostgreSQL credentials — used by both Docker Compose (to init the DB) and
# the app (via DATABASE_URL). All three must be consistent.
POSTGRES_DB=tulsajobspot
POSTGRES_USER=tulsajobspot
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Async PostgreSQL URL. Must match the POSTGRES_* values above.
DATABASE_URL=postgresql+asyncpg://tulsajobspot:change-me-to-a-strong-password@db:5432/tulsajobspot

# Redis URL. In Docker Compose, host is the service name "redis".
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# OAuth Providers
# Only providers with BOTH _CLIENT_ID and _CLIENT_SECRET set are enabled.
# Leave both blank to disable a provider.
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Email / SMTP (transactional email)
# Works with any SMTP provider: Postfix, Mailgun, SES, etc.
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost
SMTP_TLS=true

# ---------------------------------------------------------------------------
# Admin account
# Seeded as the first admin on fresh deployments.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@yourdomain.com

# ---------------------------------------------------------------------------
# AI extraction (used by scrapers — optional for Phase 1)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Site branding
# Override these for your community fork without touching code.
# ---------------------------------------------------------------------------
SITE_NAME=Tulsa Job Spot
SITE_TAGLINE=Find your next job in Tulsa, Oklahoma
CONTACT_EMAIL=hello@yourdomain.com
